{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/actions/**",
              "components/communication/**",
              "components/containment/**",
              "components/forms/**",
              "components/navigation/**",
              "components/selection/**",
              "ui_kits/marketing/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Roboto|Noto Sans KR|Material Symbols Rounded))/i]",
        "message": "Font not provided by the design system. Available: Roboto, Noto Sans KR, Material Symbols Rounded."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:count|max|dot|children|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: count, max, dot, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|icon|trailingIcon|disabled|children|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: variant, icon, trailingIcon, disabled, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|interactive|children|key|ref|className|style|children)$/]",
        "message": "<Card> doesn't accept that prop. Declared props: variant, interactive, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Checkbox'] > JSXAttribute > JSXIdentifier[name!=/^(?:checked|defaultChecked|indeterminate|disabled|error|label|onChange|style|key|ref|className|style|children)$/]",
        "message": "<Checkbox> doesn't accept that prop. Declared props: checked, defaultChecked, indeterminate, disabled, error, label, onChange, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Chip'] > JSXAttribute > JSXIdentifier[name!=/^(?:type|label|icon|avatar|selected|elevated|removable|disabled|onClick|onRemove|style|key|ref|className|style|children)$/]",
        "message": "<Chip> doesn't accept that prop. Declared props: type, label, icon, avatar, selected, elevated, removable, disabled, onClick, onRemove, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Dialog'] > JSXAttribute > JSXIdentifier[name!=/^(?:open|icon|headline|children|confirmText|cancelText|onConfirm|onCancel|onClose|key|ref|className|style|children)$/]",
        "message": "<Dialog> doesn't accept that prop. Declared props: open, icon, headline, children, confirmText, cancelText, onConfirm, onCancel, onClose."
      },
      {
        "selector": "JSXOpeningElement[name.name='Divider'] > JSXAttribute > JSXIdentifier[name!=/^(?:inset|vertical|key|ref|className|style|children)$/]",
        "message": "<Divider> doesn't accept that prop. Declared props: inset, vertical."
      },
      {
        "selector": "JSXOpeningElement[name.name='Fab'] > JSXAttribute > JSXIdentifier[name!=/^(?:size|color|icon|label|extended|disabled|ariaLabel|key|ref|className|style|children)$/]",
        "message": "<Fab> doesn't accept that prop. Declared props: size, color, icon, label, extended, disabled, ariaLabel."
      },
      {
        "selector": "JSXOpeningElement[name.name='IconButton'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|icon|filledIcon|selected|disabled|ariaLabel|key|ref|className|style|children)$/]",
        "message": "<IconButton> doesn't accept that prop. Declared props: variant, icon, filledIcon, selected, disabled, ariaLabel."
      },
      {
        "selector": "JSXOpeningElement[name.name='ListItem'] > JSXAttribute > JSXIdentifier[name!=/^(?:headline|supportingText|overline|leadingIcon|leadingAvatar|trailingIcon|trailingText|trailing|interactive|key|ref|className|style|children)$/]",
        "message": "<ListItem> doesn't accept that prop. Declared props: headline, supportingText, overline, leadingIcon, leadingAvatar, trailingIcon, trailingText, trailing, interactive."
      },
      {
        "selector": "JSXOpeningElement[name.name='MenuItem'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|label|icon|trailing|disabled|divider|key|ref|className|style|children)$/]",
        "message": "<MenuItem> doesn't accept that prop. Declared props: value, label, icon, trailing, disabled, divider."
      },
      {
        "selector": "JSXOpeningElement[name.name='NavItem'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|label|icon|badge|key|ref|className|style|children)$/]",
        "message": "<NavItem> doesn't accept that prop. Declared props: value, label, icon, badge."
      },
      {
        "selector": "JSXOpeningElement[name.name='ProgressIndicator'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|value|size|thickness|key|ref|className|style|children)$/]",
        "message": "<ProgressIndicator> doesn't accept that prop. Declared props: variant, value, size, thickness."
      },
      {
        "selector": "JSXOpeningElement[name.name='RadioButton'] > JSXAttribute > JSXIdentifier[name!=/^(?:checked|defaultChecked|disabled|name|value|label|onChange|style|key|ref|className|style|children)$/]",
        "message": "<RadioButton> doesn't accept that prop. Declared props: checked, defaultChecked, disabled, name, value, label, onChange, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Segment'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|label|icon|key|ref|className|style|children)$/]",
        "message": "<Segment> doesn't accept that prop. Declared props: value, label, icon."
      },
      {
        "selector": "JSXOpeningElement[name.name='Slider'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|defaultValue|min|max|step|disabled|showValue|onChange|style|key|ref|className|style|children)$/]",
        "message": "<Slider> doesn't accept that prop. Declared props: value, defaultValue, min, max, step, disabled, showValue, onChange, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Snackbar'] > JSXAttribute > JSXIdentifier[name!=/^(?:message|actionLabel|onAction|closable|onClose|key|ref|className|style|children)$/]",
        "message": "<Snackbar> doesn't accept that prop. Declared props: message, actionLabel, onAction, closable, onClose."
      },
      {
        "selector": "JSXOpeningElement[name.name='Switch'] > JSXAttribute > JSXIdentifier[name!=/^(?:checked|defaultChecked|disabled|icon|onChange|ariaLabel|style|key|ref|className|style|children)$/]",
        "message": "<Switch> doesn't accept that prop. Declared props: checked, defaultChecked, disabled, icon, onChange, ariaLabel, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='TabItem'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|label|icon|key|ref|className|style|children)$/]",
        "message": "<TabItem> doesn't accept that prop. Declared props: value, label, icon."
      },
      {
        "selector": "JSXOpeningElement[name.name='TextField'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|label|value|defaultValue|leadingIcon|trailingIcon|supportingText|error|disabled|onChange|key|ref|className|style|children)$/]",
        "message": "<TextField> doesn't accept that prop. Declared props: variant, label, value, defaultValue, leadingIcon, trailingIcon, supportingText, error, disabled, onChange."
      },
      {
        "selector": "JSXOpeningElement[name.name='Tooltip'] > JSXAttribute > JSXIdentifier[name!=/^(?:text|rich|subhead|position|children|style|key|ref|className|style|children)$/]",
        "message": "<Tooltip> doesn't accept that prop. Declared props: text, rich, subhead, position, children, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='AppBarAction'] > JSXAttribute > JSXIdentifier[name!=/^(?:icon|label|onClick|key|ref|className|style|children)$/]",
        "message": "<AppBarAction> doesn't accept that prop. Declared props: icon, label, onClick."
      }
    ]
  },
